# CEH AI - Configuration
# Copy this file to .env and fill in your values.

# --- Database (Neon PostgreSQL) ---
# Get a free Neon PostgreSQL database at https://neon.tech
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connect_timeout=15"
DIRECT_DATABASE_URL="postgresql://user:password@ep-xxxx.us-east-1.aws.neon.tech/neondb?sslmode=require&connect_timeout=15"

# --- AI Chat (OpenRouter) ---
# Get a free API key at https://openrouter.ai/keys
# Free models used: mistral-7b, gemma-2-9b, zephyr-7b, phi-3-mini
OPENROUTER_API_KEY="YOUR_OPENROUTER_API_KEY_HERE"

# --- Admin Access (Optional) ---
# If not set, defaults to "ceh2026" or the PIN stored in the database
ADMIN_PIN="ceh2026"
